# ==============================================
# Mnemos — Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# APPLICATION
APP_NAME=Mnemos
APP_ENV=local
APP_KEY=                        # Will be generated automatically by install.sh
APP_DEBUG=false
APP_URL=http://localhost:8000   # Change to your domain in production

# DATABASE
# These are pre-configured for Docker — change only if using your own MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1               # Use "db" when running with Docker Compose
DB_PORT=3306
DB_DATABASE=mnemos
DB_USERNAME=mnemos
DB_PASSWORD=secret              # Change this in production!
DB_ROOT_PASSWORD=rootsecret     # Docker only — change in production!

# CLOUDINARY — File Storage
# Get your credentials at: https://cloudinary.com (free plan available)
CLOUDINARY_URL=                 # Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# GOOGLE GEMINI — AI Features
# Get your API key at: https://aistudio.google.com/app/apikey (free)
GEMINI_API_KEY=

# QUEUE (leave as-is for Docker setup)
QUEUE_CONNECTION=database
CACHE_DRIVER=file
SESSION_DRIVER=file

# MAIL (optional — for password reset emails)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@mnemos.org
MAIL_FROM_NAME="${APP_NAME}"

# LOGGING
LOG_CHANNEL=stack
LOG_LEVEL=error
